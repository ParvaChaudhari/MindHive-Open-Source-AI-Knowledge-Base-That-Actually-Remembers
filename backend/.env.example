SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_key_here
GEMINI_API_KEY=your_gemini_key_here
# Optional: NVIDIA NIM configuration (for Llama models)
NVIDIA_API_KEY=your_nvidia_key_here
# Queen Bee (High Intelligence for Agents)
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# Chat (Instant Speed for Q&A)
NVIDIA_MODEL_CHAT=meta/llama-3.2-3b-instruct
# Flashcards (High Quality for Study Material)
NVIDIA_MODEL_FLASHCARD=meta/llama-3.1-8b-instruct

# Optional: CORS origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173
